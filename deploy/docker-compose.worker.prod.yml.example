services:
  worker:
    image: ${WORKER_IMAGE_NAME:-ghcr.io/jobdri-developer/analysis-worker}:${WORKER_IMAGE_TAG:-latest}
    container_name: jobdri-analysis-worker
    ports:
      - "${WORKER_METRICS_PORT:-8000}:8000"
    env_file:
      - .env
    environment:
      WORKER_ENV: prod
      SPRING_API_BASE_URL: ${WORKER_SPRING_API_BASE_URL:-http://api:8080}
      APP_WORKER_INTERNAL_API_KEY: ${APP_WORKER_INTERNAL_API_KEY}
      RABBITMQ_HOST: ${RABBITMQ_HOST:-rabbitmq}
      RABBITMQ_PORT: ${RABBITMQ_PORT:-5672}
      RABBITMQ_USERNAME: ${RABBITMQ_USERNAME}
      RABBITMQ_PASSWORD: ${RABBITMQ_PASSWORD}
      RABBITMQ_VHOST: ${RABBITMQ_VHOST:-/}
      APP_WORKER_JOB_POSTING_EXCHANGE: ${APP_WORKER_JOB_POSTING_EXCHANGE:-jobdri.worker.exchange}
      APP_WORKER_JOB_POSTING_QUEUE: ${APP_WORKER_JOB_POSTING_QUEUE:-jobdri.job-posting.ingest}
      APP_WORKER_JOB_POSTING_ROUTING_KEY: ${APP_WORKER_JOB_POSTING_ROUTING_KEY:-job-posting.ingest}
      APP_WORKER_JOB_POSTING_DLQ: ${APP_WORKER_JOB_POSTING_DLQ:-jobdri.job-posting.ingest.dlq}
      APP_WORKER_ANALYSIS_EXCHANGE: ${APP_WORKER_ANALYSIS_EXCHANGE:-jobdri.worker.exchange}
      APP_WORKER_ANALYSIS_QUEUE: ${APP_WORKER_ANALYSIS_QUEUE:-jobdri.analysis.execute}
      APP_WORKER_ANALYSIS_ROUTING_KEY: ${APP_WORKER_ANALYSIS_ROUTING_KEY:-analysis.execute}
      APP_WORKER_ANALYSIS_DLQ: ${APP_WORKER_ANALYSIS_DLQ:-jobdri.analysis.execute.dlq}
      WORKER_PREFETCH_COUNT: ${WORKER_PREFETCH_COUNT:-1}
      WORKER_DEFAULT_CONCURRENCY_LIMIT: ${WORKER_DEFAULT_CONCURRENCY_LIMIT:-1}
      WORKER_ANALYSIS_CONCURRENCY_LIMIT: ${WORKER_ANALYSIS_CONCURRENCY_LIMIT:-1}
      WORKER_JOB_POSTING_CONCURRENCY_LIMIT: ${WORKER_JOB_POSTING_CONCURRENCY_LIMIT:-1}
      OPENAI_API_KEY: ${OPENAI_API_KEY}
      OPENAI_JOB_POSTING_MODEL: ${OPENAI_JOB_POSTING_MODEL:-gpt-4o-mini}
      OPENAI_ANALYSIS_MODEL: ${OPENAI_ANALYSIS_MODEL:-gpt-4.1-mini}
      JOB_POSTING_CLASSIFICATION_CONFIDENCE_THRESHOLD: ${JOB_POSTING_CLASSIFICATION_CONFIDENCE_THRESHOLD:-0.65}
      WORKER_MAX_RETRY_COUNT: ${WORKER_MAX_RETRY_COUNT:-3}
      APP_WORKER_ANALYSIS_MAX_RETRY_COUNT: ${APP_WORKER_ANALYSIS_MAX_RETRY_COUNT:-3}
      APP_WORKER_ANALYSIS_QUEUE_TIMEOUT_MILLIS: ${APP_WORKER_ANALYSIS_QUEUE_TIMEOUT_MILLIS:-300000}
    restart: unless-stopped
